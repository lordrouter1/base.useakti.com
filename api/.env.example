# ==============================================================
# Akti API - Variáveis de Ambiente
# ==============================================================
# Copie este arquivo para .env e preencha os valores adequados.
# NÃO commite o arquivo .env no repositório.
# ==============================================================

# --- Aplicação ---
NODE_ENV=development
PORT=3000

# --- Banco de Dados (MySQL) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=akti
DB_USER=root
DB_PASS=

# --- JWT (compatível com o sistema PHP legado) ---
JWT_SECRET=your_jwt_secret_here

# --- CORS ---
# Domínio base para permitir subdomínios (ex: .useakti.com)
CORS_ORIGIN_PATTERN=.useakti.com

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
