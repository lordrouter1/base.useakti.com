{
    "name": "akti/gestao-producao",
    "description": "Akti - Gestão em Produção — Sistema de gestão focado na linha de produção",
    "type": "project",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "Akti\\Core\\": "app/core/",
            "Akti\\Controllers\\": "app/controllers/",
            "Akti\\Models\\": "app/models/",
            "Akti\\Config\\": "app/config/",
            "Akti\\Services\\": "app/services/",
            "Akti\\Middleware\\": "app/middleware/",
            "Akti\\Utils\\": "app/utils/",
            "Akti\\Security\\": "app/security/",
            "Akti\\Gateways\\": "app/gateways/"
        },
        "classmap": [
            "app/config/database.php",
            "app/config/tenant.php",
            "app/config/session.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Akti\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
