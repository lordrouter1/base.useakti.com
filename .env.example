# ─────────────────────────────────────────────────
# Akti — Gestão em Produção
# Variáveis de Ambiente
# ─────────────────────────────────────────────────
# Copie este arquivo como .env e preencha os valores.
# NUNCA commite o arquivo .env no repositório.
# ─────────────────────────────────────────────────

# ── Ambiente ──────────────────────────────────────
APP_ENV=development
# Opções: development, staging, production

# ── Banco de Dados (Tenant padrão) ───────────────
AKTI_DB_HOST=localhost
AKTI_DB_PORT=3306
AKTI_DB_NAME=akti_teste
AKTI_DB_USER=akti_sis_usr
AKTI_DB_PASS=
AKTI_DB_CHARSET=utf8mb4

# ── Banco de Dados Master (Multi-Tenant) ─────────
# Se não definido, usa as mesmas credenciais do tenant
AKTI_MASTER_DB_HOST=
AKTI_MASTER_DB_PORT=
AKTI_MASTER_DB_NAME=akti_master
AKTI_MASTER_DB_USER=
AKTI_MASTER_DB_PASS=
AKTI_MASTER_DB_CHARSET=utf8mb4

# ── Domínio Base (Multi-Tenant) ──────────────────
AKTI_BASE_DOMAIN=useakti.com

# ── reCAPTCHA (proteção brute force) ─────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Chave de criptografia da aplicação (OBRIGATÓRIA em produção)
# Usada para criptografar senhas de certificados digitais (NF-e)
# Gere uma chave segura com: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# ── API Node.js ──────────────────────────────────
AKTI_API_URL=http://localhost:3000
AKTI_API_JWT_SECRET=

# ── Sentry (Error Tracking) ─────────────────────
# Deixe vazio para desabilitar. Para ativar:
# 1. Crie uma conta em https://sentry.io
# 2. Crie um projeto PHP e copie o DSN
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.2

# ── Backup ────────────────────────────────────────
BACKUP_STORAGE_PATH=./storage/backups
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_WEEKS=4
# S3/Cloud Storage (opcional)
BACKUP_S3_BUCKET=
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
BACKUP_S3_REGION=us-east-1

# ── Logging ───────────────────────────────────────
LOG_LEVEL=info
# Opções: debug, info, notice, warning, error, critical, alert, emergency
LOG_PATH=./storage/logs

# ── E-mail (SMTP) ────────────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=noreply@akti.com.br
MAIL_FROM_NAME=Akti Sistema
