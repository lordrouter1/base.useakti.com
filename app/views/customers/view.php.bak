-->

<div class="container-fluid py-4">
    <div class="row mb-3">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="?page=customers">Clientes</a></li>
                    <li class="breadcrumb-item active" aria-current="page"><?= htmlspecialchars($customer['name']) ?></li>
                </ol>
            </nav>
        </div>
        <div class="col-auto">
            <a href="?page=customers&action=edit&id=<?= $customer['id'] ?>" class="btn btn-primary btn-sm">
                <i class="fas fa-edit"></i> Editar
            </a>
            <a href="?page=customers" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Voltar
            </a>
        </div>
    </div>

    <!-- Cabeçalho do Cliente -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-auto">
                    <?php if (!empty($customer['photo'])): ?>
                        <img src="<?= htmlspecialchars($customer['photo']) ?>" alt="Foto" class="rounded-circle" style="width:80px;height:80px;object-fit:cover;">
                    <?php else: ?>
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:80px;height:80px;font-size:2rem;">
                            <?= strtoupper(mb_substr($customer['name'], 0, 1)) ?>
                        </div>
                    <?php endif; ?>
                </div>
                <div class="col">
                    <h3 class="mb-1"><?= htmlspecialchars($customer['name']) ?></h3>
                    <div class="text-muted">
                        <span class="badge bg-<?= ($customer['person_type'] ?? 'PF') === 'PJ' ? 'info' : 'secondary' ?>">
                            <?= ($customer['person_type'] ?? 'PF') === 'PJ' ? 'Pessoa Jurídica' : 'Pessoa Física' ?>
                        </span>
                        <?php if (!empty($customer['code'])): ?>
                            <span class="ms-2"><i class="fas fa-barcode"></i> <?= htmlspecialchars($customer['code']) ?></span>
                        <?php endif; ?>
                        <?php
                        $statusMap = [
                            'active'   => ['Ativo', 'success'],
                            'inactive' => ['Inativo', 'warning'],
                            'blocked'  => ['Bloqueado', 'danger'],
                        ];
                        $st = $statusMap[$customer['status'] ?? 'active'] ?? ['Ativo', 'success'];
                        ?>
                        <span class="badge bg-<?= $st[1] ?> ms-2"><?= $st[0] ?></span>
                    </div>
                    <?php if (!empty($customer['fantasy_name'])): ?>
                        <small class="text-muted">Nome Fantasia: <?= htmlspecialchars($customer['fantasy_name']) ?></small>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    </div>

    <!-- Cards de Estatísticas -->
    <div class="row mb-4">
        <div class="col-md-3 col-6 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body py-3">
                    <h4 class="mb-0 text-primary"><?= (int)($stats['total_orders'] ?? 0) ?></h4>
                    <small class="text-muted">Total de Pedidos</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body py-3">
                    <h4 class="mb-0 text-success">R$ <?= number_format($stats['total_value'] ?? 0, 2, ',', '.') ?></h4>
                    <small class="text-muted">Valor Total</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body py-3">
                    <h4 class="mb-0 text-info">R$ <?= number_format($stats['avg_ticket'] ?? 0, 2, ',', '.') ?></h4>
                    <small class="text-muted">Ticket Médio</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body py-3">
                    <h4 class="mb-0 text-warning">
                        <?= !empty($stats['last_order_date']) ? date('d/m/Y', strtotime($stats['last_order_date'])) : '—' ?>
                    </h4>
                    <small class="text-muted">Último Pedido</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Coluna Esquerda: Dados do Cliente -->
        <div class="col-lg-8">
            <!-- Dados de Identificação -->
            <div class="card shadow-sm mb-4">
                <div class="card-header"><h6 class="mb-0"><i class="fas fa-id-card me-2"></i>Identificação</h6></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <strong>Documento (<?= ($customer['person_type'] ?? 'PF') === 'PJ' ? 'CNPJ' : 'CPF' ?>):</strong><br>
                            <?php
                            $doc = $customer['document'] ?? '';
                            if (strlen($doc) === 11) {
                                echo substr($doc,0,3).'.'.substr($doc,3,3).'.'.substr($doc,6,3).'-'.substr($doc,9,2);
                            } elseif (strlen($doc) === 14) {
                                echo substr($doc,0,2).'.'.substr($doc,2,3).'.'.substr($doc,5,3).'/'.substr($doc,8,4).'-'.substr($doc,12,2);
                            } else {
                                echo htmlspecialchars($doc) ?: '—';
                            }
                            ?>
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong><?= ($customer['person_type'] ?? 'PF') === 'PJ' ? 'Inscrição Estadual' : 'RG' ?>:</strong><br>
                            <?= htmlspecialchars($customer['rg_ie'] ?? '') ?: '—' ?>
                        </div>
                        <?php if (($customer['person_type'] ?? 'PF') === 'PJ'): ?>
                        <div class="col-md-6 mb-2">
                            <strong>Inscrição Municipal:</strong><br>
                            <?= htmlspecialchars($customer['im'] ?? '') ?: '—' ?>
                        </div>
                        <?php endif; ?>
                        <div class="col-md-6 mb-2">
                            <strong><?= ($customer['person_type'] ?? 'PF') === 'PJ' ? 'Data de Fundação' : 'Data de Nascimento' ?>:</strong><br>
                            <?= !empty($customer['birth_date']) ? date('d/m/Y', strtotime($customer['birth_date'])) : '—' ?>
                        </div>
                        <?php if (($customer['person_type'] ?? 'PF') === 'PF' && !empty($customer['gender'])): ?>
                        <div class="col-md-6 mb-2">
                            <strong>Gênero:</strong><br>
                            <?php
                            $genderMap = ['M' => 'Masculino', 'F' => 'Feminino', 'O' => 'Outro'];
                            echo $genderMap[$customer['gender']] ?? '—';
                            ?>
                        </div>
                        <?php endif; ?>
                    </div>
                </div>
            </div>

            <!-- Dados de Contato -->
            <div class="card shadow-sm mb-4">
                <div class="card-header"><h6 class="mb-0"><i class="fas fa-phone me-2"></i>Contato</h6></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <strong>E-mail:</strong><br>
                            <?php if (!empty($customer['email'])): ?>
                                <a href="mailto:<?= htmlspecialchars($customer['email']) ?>"><?= htmlspecialchars($customer['email']) ?></a>
                            <?php else: ?>—<?php endif; ?>
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>E-mail Secundário:</strong><br>
                            <?= !empty($customer['email_secondary']) ? '<a href="mailto:'.htmlspecialchars($customer['email_secondary']).'">'.htmlspecialchars($customer['email_secondary']).'</a>' : '—' ?>
                        </div>
                        <div class="col-md-4 mb-2">
                            <strong>Telefone:</strong><br>
                            <?= htmlspecialchars($customer['phone'] ?? '') ?: '—' ?>
                        </div>
                        <div class="col-md-4 mb-2">
                            <strong>Celular:</strong><br>
                            <?= htmlspecialchars($customer['cellphone'] ?? '') ?: '—' ?>
                        </div>
                        <div class="col-md-4 mb-2">
                            <strong>Comercial:</strong><br>
                            <?= htmlspecialchars($customer['phone_commercial'] ?? '') ?: '—' ?>
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>Website:</strong><br>
                            <?php if (!empty($customer['website'])): ?>
                                <a href="<?= htmlspecialchars($customer['website']) ?>" target="_blank"><?= htmlspecialchars($customer['website']) ?></a>
                            <?php else: ?>—<?php endif; ?>
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>Instagram:</strong><br>
                            <?php if (!empty($customer['instagram'])): ?>
                                <a href="https://instagram.com/<?= htmlspecialchars($customer['instagram']) ?>" target="_blank">@<?= htmlspecialchars($customer['instagram']) ?></a>
                            <?php else: ?>—<?php endif; ?>
                        </div>
                    </div>
                    <?php if (($customer['person_type'] ?? 'PF') === 'PJ' && (!empty($customer['contact_name']) || !empty($customer['contact_role']))): ?>
                    <hr>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <strong>Contato Principal:</strong><br>
                            <?= htmlspecialchars($customer['contact_name'] ?? '') ?: '—' ?>
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>Cargo:</strong><br>
                            <?= htmlspecialchars($customer['contact_role'] ?? '') ?: '—' ?>
                        </div>
                    </div>
                    <?php endif; ?>
                </div>
            </div>

            <!-- Endereço -->
            <div class="card shadow-sm mb-4">
                <div class="card-header"><h6 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>Endereço</h6></div>
                <div class="card-body">
                    <?php
                    $hasAddress = !empty($customer['address_street']) || !empty($customer['zipcode']);
                    if ($hasAddress):
                        $address = trim(
                            ($customer['address_street'] ?? '') .
                            (!empty($customer['address_number']) ? ', ' . $customer['address_number'] : '') .
                            (!empty($customer['address_complement']) ? ' - ' . $customer['address_complement'] : '')
                        );
                    ?>
                    <p class="mb-1"><?= htmlspecialchars($address) ?></p>
                    <p class="mb-1">
                        <?= htmlspecialchars($customer['address_neighborhood'] ?? '') ?>
                        <?php if (!empty($customer['address_city']) || !empty($customer['address_state'])): ?>
                            — <?= htmlspecialchars($customer['address_city'] ?? '') ?>/<?= htmlspecialchars($customer['address_state'] ?? '') ?>
                        <?php endif; ?>
                    </p>
                    <?php if (!empty($customer['zipcode'])): ?>
                        <p class="mb-1 text-muted">CEP: <?= htmlspecialchars($customer['zipcode']) ?></p>
                    <?php endif; ?>
                    <?php if (!empty($customer['address_ibge'])): ?>
                        <p class="mb-0 text-muted"><small>IBGE: <?= htmlspecialchars($customer['address_ibge']) ?></small></p>
                    <?php endif; ?>
                    <?php else: ?>
                        <p class="text-muted mb-0">Endereço não informado.</p>
                    <?php endif; ?>
                </div>
            </div>

            <!-- Últimos Pedidos -->
            <div class="card shadow-sm mb-4">
                <div class="card-header"><h6 class="mb-0"><i class="fas fa-shopping-cart me-2"></i>Últimos Pedidos</h6></div>
                <div class="card-body p-0">
                    <?php if (!empty($recentOrders)): ?>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Valor</th>
                                    <th>Status</th>
                                    <th>Data</th>
                                </tr>
                            </thead>
                            <tbody>
                                <?php foreach ($recentOrders as $order): ?>
                                <tr>
                                    <td><a href="?page=orders&action=edit&id=<?= $order['id'] ?>">#<?= $order['id'] ?></a></td>
                                    <td>R$ <?= number_format($order['total_amount'] ?? 0, 2, ',', '.') ?></td>
                                    <td><span class="badge bg-secondary"><?= htmlspecialchars($order['status'] ?? '') ?></span></td>
                                    <td><?= !empty($order['created_at']) ? date('d/m/Y', strtotime($order['created_at'])) : '—' ?></td>
                                </tr>
                                <?php endforeach; ?>
                            </tbody>
                        </table>
                    </div>
                    <?php else: ?>
                        <div class="p-3 text-center text-muted">Nenhum pedido encontrado.</div>
                    <?php endif; ?>
                </div>
            </div>
        </div>

        <!-- Coluna Direita: Dados Comerciais + Contatos -->
        <div class="col-lg-4">
            <!-- Dados Comerciais -->
            <div class="card shadow-sm mb-4">
                <div class="card-header"><h6 class="mb-0"><i class="fas fa-handshake me-2"></i>Comercial</h6></div>
                <div class="card-body">
                    <p><strong>Tabela de Preço:</strong><br> <?= htmlspecialchars($priceTable['name'] ?? '') ?: '—' ?></p>
                    <p><strong>Condição de Pagamento:</strong><br> <?= htmlspecialchars($customer['payment_term'] ?? '') ?: '—' ?></p>
                    <p><strong>Limite de Crédito:</strong><br>
                        <?= ($customer['credit_limit'] !== null && $customer['credit_limit'] !== '') ? 'R$ ' . number_format((float)$customer['credit_limit'], 2, ',', '.') : '—' ?>
                    </p>
                    <p><strong>Desconto Padrão:</strong><br>
                        <?= ($customer['discount_default'] !== null && $customer['discount_default'] !== '') ? number_format((float)$customer['discount_default'], 2, ',', '.') . '%' : '—' ?>
                    </p>
                    <p><strong>Vendedor:</strong><br> <?= htmlspecialchars($sellerName ?? '') ?: '—' ?></p>
                    <p class="mb-0"><strong>Origem:</strong><br> <?= htmlspecialchars($customer['origin'] ?? '') ?: '—' ?></p>
                </div>
            </div>

            <!-- Tags -->
            <?php if (!empty($customer['tags'])): ?>
            <div class="card shadow-sm mb-4">
                <div class="card-header"><h6 class="mb-0"><i class="fas fa-tags me-2"></i>Tags</h6></div>
                <div class="card-body">
                    <?php foreach (explode(',', $customer['tags']) as $tag): $tag = trim($tag); if ($tag): ?>
                        <span class="badge bg-light text-dark border me-1 mb-1"><?= htmlspecialchars($tag) ?></span>
                    <?php endif; endforeach; ?>
                </div>
            </div>
            <?php endif; ?>

            <!-- Observações -->
            <?php if (!empty($customer['observations'])): ?>
            <div class="card shadow-sm mb-4">
                <div class="card-header"><h6 class="mb-0"><i class="fas fa-sticky-note me-2"></i>Observações</h6></div>
                <div class="card-body">
                    <p class="mb-0"><?= nl2br(htmlspecialchars($customer['observations'])) ?></p>
                </div>
            </div>
            <?php endif; ?>

            <!-- Contatos Adicionais (PJ) -->
            <?php if (!empty($contacts)): ?>
            <div class="card shadow-sm mb-4">
                <div class="card-header"><h6 class="mb-0"><i class="fas fa-users me-2"></i>Contatos Adicionais</h6></div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <?php foreach ($contacts as $contact): ?>
                        <li class="list-group-item">
                            <strong><?= htmlspecialchars($contact['name']) ?></strong>
                            <?php if (!empty($contact['is_primary'])): ?>
                                <span class="badge bg-primary ms-1">Principal</span>
                            <?php endif; ?>
                            <?php if (!empty($contact['role'])): ?>
                                <br><small class="text-muted"><?= htmlspecialchars($contact['role']) ?></small>
                            <?php endif; ?>
                            <?php if (!empty($contact['email'])): ?>
                                <br><small><a href="mailto:<?= htmlspecialchars($contact['email']) ?>"><?= htmlspecialchars($contact['email']) ?></a></small>
                            <?php endif; ?>
                            <?php if (!empty($contact['phone'])): ?>
                                <br><small><?= htmlspecialchars($contact['phone']) ?></small>
                            <?php endif; ?>
                        </li>
                        <?php endforeach; ?>
                    </ul>
                </div>
            </div>
            <?php endif; ?>

            <!-- Auditoria -->
            <div class="card shadow-sm mb-4">
                <div class="card-header"><h6 class="mb-0"><i class="fas fa-history me-2"></i>Auditoria</h6></div>
                <div class="card-body">
                    <p class="mb-1"><strong>Cadastrado em:</strong><br>
                        <?= !empty($customer['created_at']) ? date('d/m/Y H:i', strtotime($customer['created_at'])) : '—' ?>
                    </p>
                    <?php if (!empty($customer['updated_at'])): ?>
                    <p class="mb-0"><strong>Atualizado em:</strong><br>
                        <?= date('d/m/Y H:i', strtotime($customer['updated_at'])) ?>
                    </p>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    </div>
</div>
