{# Footer — E-commerce style #}
{% set ftr_bg = theme.footer_bg_color|default('#232f3e') %}
{% set ftr_text = theme.footer_text_color|default('#dddddd') %}

{# Back to top #}
{% set btt_bg = theme.back_to_top_bg_color|default('#37475a') %}
{% set btt_text = theme.back_to_top_text_color|default('#ffffff') %}
{% set btt_font = theme.back_to_top_font|default('Inter') %}
<a href="#" class="footer-back-top d-block text-center py-3 text-decoration-none" style="background:{{ btt_bg }};color:{{ btt_text }};font-family:'{{ btt_font }}',sans-serif;">
    <small>Voltar ao topo</small>
</a>

<footer class="store-footer" style="background:{{ ftr_bg }};color:{{ ftr_text }};">
    <div class="container py-5">
        <div class="row g-4">
            {# Col 1 — Categorias #}
            <div class="col-6 col-md-3">
                <h6 class="fw-bold text-white mb-3">Categorias</h6>
                <ul class="list-unstyled small">
                    {% for cat in categories|default([])|slice(0, 8) %}
                        <li class="mb-1">
                            <a href="/loja/produtos?category={{ cat.id }}" class="footer-link">{{ cat.name }}</a>
                        </li>
                    {% endfor %}
                    <li><a href="/loja/produtos" class="footer-link">Ver todas &raquo;</a></li>
                </ul>
            </div>

            {# Col 2 — Links #}
            <div class="col-6 col-md-3">
                <h6 class="fw-bold text-white mb-3">Navegação</h6>
                <ul class="list-unstyled small">
                    {% for item in menu|default([]) %}
                        <li class="mb-1">
                            <a href="{{ item.url }}" class="footer-link">{{ item.label }}</a>
                        </li>
                    {% endfor %}
                    <li class="mb-1"><a href="/loja/perfil" class="footer-link">Minha Conta</a></li>
                    <li class="mb-1"><a href="/loja/carrinho" class="footer-link">Carrinho</a></li>
                </ul>
            </div>

            {# Col 3 — Contato #}
            <div class="col-6 col-md-3">
                <h6 class="fw-bold text-white mb-3">Contato</h6>
                <ul class="list-unstyled small">
                    {% if shop.email|default('') %}
                        <li class="mb-2"><i class="fas fa-envelope me-2 opacity-50"></i>{{ shop.email }}</li>
                    {% endif %}
                    {% if shop.phone|default('') %}
                        <li class="mb-2"><i class="fas fa-phone me-2 opacity-50"></i>{{ shop.phone }}</li>
                    {% endif %}
                    {% if shop.address|default('') %}
                        <li class="mb-2"><i class="fas fa-map-marker-alt me-2 opacity-50"></i>{{ shop.address }}</li>
                    {% endif %}
                    {% if shop.whatsapp|default('') %}
                        <li class="mb-2">
                            <a href="https://wa.me/{{ shop.whatsapp }}" target="_blank" class="footer-link">
                                <i class="fab fa-whatsapp me-2"></i>WhatsApp
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </div>

            {# Col 4 — Redes sociais + About #}
            <div class="col-6 col-md-3">
                <h6 class="fw-bold text-white mb-3">{{ shop.name|default('Sobre') }}</h6>
                {% if theme.footer_text|default('') %}
                    <p class="small opacity-75">{{ theme.footer_text }}</p>
                {% else %}
                    <p class="small opacity-75">{{ shop.description|default('')|slice(0,120) }}</p>
                {% endif %}
                <div class="d-flex gap-3 mt-2">
                    {% if theme.social_facebook|default('') %}
                        <a href="{{ theme.social_facebook }}" target="_blank" class="footer-social"><i class="fab fa-facebook fa-lg"></i></a>
                    {% endif %}
                    {% if theme.social_instagram|default('') %}
                        <a href="{{ theme.social_instagram }}" target="_blank" class="footer-social"><i class="fab fa-instagram fa-lg"></i></a>
                    {% endif %}
                    {% if theme.social_whatsapp|default('') %}
                        <a href="https://wa.me/{{ theme.social_whatsapp }}" target="_blank" class="footer-social"><i class="fab fa-whatsapp fa-lg"></i></a>
                    {% endif %}
                    {% if theme.social_twitter|default('') %}
                        <a href="{{ theme.social_twitter }}" target="_blank" class="footer-social"><i class="fab fa-x-twitter fa-lg"></i></a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div style="background:#131a22;">
        <div class="container py-3">
            <p class="text-center small mb-0 opacity-50" style="color:{{ ftr_text }};">
                &copy; {{ 'now'|date('Y') }} {{ shop.name|default('Minha Loja') }}. Todos os direitos reservados.
            </p>
        </div>
    </div>
</footer>
