{% extends 'layouts/base.html.twig' %}

{% block title %}{{ shop.name|default('Minha Loja') }}{% endblock %}

{% block content %}
    {# ── Hero / Banner Carousel ── #}
    {% set hero_bg = theme.hero_image_url|default('') %}
    <section class="home-hero mb-3">
        <div class="container-fluid px-3 px-lg-4">
            <div class="row g-3">
                {# Categories sidebar — desktop only #}
                <div class="col-lg-2 d-none d-lg-block">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-0">
                            <ul class="list-unstyled mb-0 cat-sidebar">
                                {% for cat in categories|default([]) %}
                                    <li>
                                        <a href="/loja/produtos?category={{ cat.id }}" class="cat-sidebar-link d-flex align-items-center justify-content-between">
                                            <span>{{ cat.name }}</span>
                                            {% if cat.subcategories|default([])|length > 0 %}
                                                <i class="fas fa-chevron-right small opacity-50"></i>
                                            {% endif %}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>

                {# Main banner / Carousel #}
                <div class="col-lg-8 col-12">
                    {% set carousel_on = theme.carousel_enabled|default('0') in ['1', 'true'] %}
                    {# Build carousel slides from settings #}
                    {% set slides = [] %}
                    {% for i in 1..5 %}
                        {% set img_key = 'carousel_image_' ~ i %}
                        {% set link_key = 'carousel_link_' ~ i %}
                        {% if theme[img_key]|default('') %}
                            {% set slides = slides|merge([{ 'image': theme[img_key], 'link': theme[link_key]|default('') }]) %}
                        {% endif %}
                    {% endfor %}

                    {% if carousel_on and slides|length > 0 %}
                        {# ── Image Carousel ── #}
                        {% set autoplay = theme.carousel_autoplay|default('1') in ['1', 'true'] %}
                        {% set interval_ms = theme.carousel_interval|default('5000') %}
                        <div id="heroCarousel" class="carousel slide rounded overflow-hidden" {% if autoplay %}data-bs-ride="carousel" data-bs-interval="{{ interval_ms }}"{% endif %}>
                            <div class="carousel-indicators">
                                {% for slide in slides %}
                                    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="{{ loop.index0 }}" {% if loop.first %}class="active"{% endif %}></button>
                                {% endfor %}
                            </div>
                            <div class="carousel-inner">
                                {% for slide in slides %}
                                    <div class="carousel-item {% if loop.first %}active{% endif %}">
                                        {% if slide.link %}
                                            <a href="{{ slide.link }}">
                                                <img src="{{ slide.image }}" class="d-block w-100" alt="Slide {{ loop.index }}" style="height:340px;object-fit:cover;">
                                            </a>
                                        {% else %}
                                            <img src="{{ slide.image }}" class="d-block w-100" alt="Slide {{ loop.index }}" style="height:340px;object-fit:cover;">
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            </div>
                            {% if slides|length > 1 %}
                                <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon"></span>
                                </button>
                            {% endif %}
                        </div>
                    {% else %}
                        {# ── Static hero banner (fallback) ── #}
                        <div class="hero-banner rounded overflow-hidden position-relative" style="{% if hero_bg %}background:url('{{ hero_bg }}') center/cover no-repeat;{% else %}background:linear-gradient(135deg, var(--primary), var(--primary-dark));{% endif %} min-height:340px;">
                            {% if hero_bg %}<div class="position-absolute top-0 start-0 w-100 h-100" style="background:rgba(0,0,0,0.35);"></div>{% endif %}
                            <div class="position-relative d-flex flex-column justify-content-center h-100 p-4 p-lg-5 text-white" style="min-height:340px;">
                                <h1 class="fw-bold mb-2" style="font-size:clamp(1.5rem,3vw,2.2rem);">{{ theme.hero_title|default('Bem-vindo à nossa loja') }}</h1>
                                <p class="mb-3 opacity-90" style="max-width:500px;">{{ theme.hero_subtitle|default('Encontre os melhores produtos com os melhores preços') }}</p>
                                {% if theme.hero_cta_text|default('') %}
                                    <div>
                                        <a href="{{ theme.hero_cta_url|default('/loja/produtos') }}" class="btn btn-warning btn-lg fw-bold px-4">
                                            {{ theme.hero_cta_text }}
                                        </a>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                </div>

                {# Side cards — desktop #}
                <div class="col-lg-2 d-none d-lg-flex flex-column gap-3">
                    <div class="card border-0 shadow-sm flex-fill">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-3">
                            <i class="fas fa-truck fa-2x mb-2" style="color:var(--primary);"></i>
                            <small class="fw-bold">Entrega Rápida</small>
                            <small class="text-muted">Para todo o Brasil</small>
                        </div>
                    </div>
                    <div class="card border-0 shadow-sm flex-fill">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-3">
                            <i class="fas fa-shield-alt fa-2x mb-2" style="color:var(--primary);"></i>
                            <small class="fw-bold">Compra Segura</small>
                            <small class="text-muted">Seus dados protegidos</small>
                        </div>
                    </div>
                    <div class="card border-0 shadow-sm flex-fill">
                        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-3">
                            <i class="fas fa-headset fa-2x mb-2" style="color:var(--primary);"></i>
                            <small class="fw-bold">Suporte</small>
                            <small class="text-muted">Atendimento dedicado</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ── Category cards (mobile + desktop) ── #}
    {% if categories|default([])|length > 0 %}
    <section class="py-3">
        <div class="container-fluid px-3 px-lg-4">
            <h2 class="fs-5 fw-bold mb-3">Navegue por Categorias</h2>
            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-2">
                {% for cat in categories|default([])|slice(0, 12) %}
                    <div class="col">
                        <a href="/loja/produtos?category={{ cat.id }}" class="card border-0 shadow-sm text-decoration-none h-100 cat-card">
                            <div class="card-body text-center py-3 px-2">
                                <i class="fas fa-tag fa-lg mb-2" style="color:var(--primary);"></i>
                                <p class="small fw-semibold mb-0 text-dark">{{ cat.name }}</p>
                                {% if cat.subcategories|default([])|length > 0 %}
                                    <small class="text-muted">{{ cat.subcategories|length }} sub</small>
                                {% endif %}
                            </div>
                        </a>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
    {% endif %}

    {# ── Featured Products ── #}
    {% if theme.show_featured_products|default('1') == '1' or theme.show_featured_products|default('') == 'true' %}
    <section class="py-3">
        <div class="container-fluid px-3 px-lg-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h2 class="fs-5 fw-bold mb-0">{{ theme.featured_products_title|default('Produtos em Destaque') }}</h2>
                <a href="/loja/produtos" class="small text-decoration-none" style="color:var(--primary);">Ver todos &raquo;</a>
            </div>
            {% if products|default([])|length > 0 %}
                <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-xl-5 g-2 g-md-3">
                    {% for product in products %}
                        <div class="col">
                            {% include 'snippets/product-card.html.twig' with {'product': product} %}
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center text-muted py-5">
                        <i class="fas fa-box-open fa-2x mb-2 d-block opacity-50"></i>
                        <p class="mb-0">Nenhum produto disponível no momento.</p>
                    </div>
                </div>
            {% endif %}
        </div>
    </section>
    {% endif %}

    {# ── Products by Category ── #}
    {% for cat in categories|default([])|slice(0, 4) %}
        <section class="py-3">
            <div class="container-fluid px-3 px-lg-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h2 class="fs-5 fw-bold mb-0">{{ cat.name }}</h2>
                    <a href="/loja/produtos?category={{ cat.id }}" class="small text-decoration-none" style="color:var(--primary);">Ver mais &raquo;</a>
                </div>
                <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-xl-5 g-2 g-md-3 products-by-cat" data-category="{{ cat.id }}">
                    {# Products loaded via inherited context or lazy JS #}
                </div>
            </div>
        </section>
    {% endfor %}

    {# ── About section ── #}
    {% if theme.about_text|default('') %}
    <section class="py-4">
        <div class="container-fluid px-3 px-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="row align-items-center g-4">
                        {% if theme.about_image_url|default('') %}
                            <div class="col-md-4">
                                <img src="{{ theme.about_image_url }}" class="img-fluid rounded" alt="{{ theme.about_title|default('Sobre Nós') }}">
                            </div>
                            <div class="col-md-8">
                        {% else %}
                            <div class="col-12">
                        {% endif %}
                            <h2 class="h5 fw-bold mb-3">{{ theme.about_title|default('Sobre Nós') }}</h2>
                            <p class="text-muted mb-0">{{ theme.about_text|nl2br }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    {% endif %}
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    {# Live search #}
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');
    let debounceTimer;

    if (searchInput && searchResults) {
        searchInput.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            const q = this.value.trim();
            if (q.length < 2) { searchResults.classList.add('d-none'); return; }
            debounceTimer = setTimeout(() => {
                fetch('/loja/api/search?q=' + encodeURIComponent(q))
                    .then(r => r.json())
                    .then(data => {
                        if (!data.results || data.results.length === 0) {
                            searchResults.innerHTML = '<div class="p-3 text-muted small">Nenhum resultado encontrado</div>';
                        } else {
                            searchResults.innerHTML = data.results.map(p => `
                                <a href="/loja/produto/${p.id}" class="search-item d-flex align-items-center gap-2 px-3 py-2 text-decoration-none">
                                    <img src="${p.image || '/loja/assets/images/placeholder.svg'}" width="40" height="40" class="rounded" style="object-fit:cover;">
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="small fw-semibold text-truncate text-dark">${p.name}</div>
                                        <div class="small text-muted">${p.category || ''}</div>
                                    </div>
                                    <span class="small fw-bold text-nowrap" style="color:var(--primary);">R$ ${parseFloat(p.price).toFixed(2).replace('.',',')}</span>
                                </a>
                            `).join('');
                        }
                        searchResults.classList.remove('d-none');
                    })
                    .catch(() => searchResults.classList.add('d-none'));
            }, 300);
        });

        document.addEventListener('click', function(e) {
            if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                searchResults.classList.add('d-none');
            }
        });
    }

    {# Load products by category #}
    document.querySelectorAll('.products-by-cat').forEach(container => {
        const catId = container.dataset.category;
        fetch('/loja/api/search?q=&category=' + catId)
            .catch(() => {});
        {# Fallback: load via page products endpoint #}
        fetch('/loja/produtos?category=' + catId + '&format=partial')
            .catch(() => {});
    });
});
</script>
{% endblock %}
