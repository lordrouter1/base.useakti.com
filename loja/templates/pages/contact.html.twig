{% extends 'layouts/base.html.twig' %}

{% block title %}Contato — {{ shop.name|default('Minha Loja') }}{% endblock %}

{% block content %}
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-7">
                <h1 class="h2 mb-4">Entre em Contato</h1>

                <form method="post" action="/loja/contato">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Nome</label>
                            <input type="text" class="form-control" name="name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-mail</label>
                            <input type="email" class="form-control" name="email" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Assunto</label>
                            <input type="text" class="form-control" name="subject">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Mensagem</label>
                            <textarea class="form-control" name="message" rows="5" required></textarea>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-2"></i>Enviar Mensagem
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="col-md-5">
                {% if shop.address or shop.phone or shop.email or theme.contact_whatsapp|default('') or theme.contact_hours|default('') %}
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Informações de Contato</h5>
                        {% if shop.address %}
                            <p class="mb-2"><i class="fas fa-map-marker-alt me-2 text-primary"></i>{{ shop.address|nl2br }}</p>
                        {% endif %}
                        {% if shop.phone %}
                            <p class="mb-2"><i class="fas fa-phone me-2 text-primary"></i>{{ shop.phone }}</p>
                        {% endif %}
                        {% if shop.email %}
                            <p class="mb-2"><i class="fas fa-envelope me-2 text-primary"></i>{{ shop.email }}</p>
                        {% endif %}
                        {% if theme.contact_whatsapp|default('') %}
                            <p class="mb-2"><i class="fab fa-whatsapp me-2 text-success"></i>{{ theme.contact_whatsapp }}</p>
                        {% endif %}
                        {% if theme.contact_hours|default('') %}
                            <p class="mb-0"><i class="fas fa-clock me-2 text-primary"></i>{{ theme.contact_hours }}</p>
                        {% endif %}
                    </div>
                </div>
                {% endif %}

                {% if theme.contact_map_embed|default('') %}
                <div class="mt-3">
                    <iframe src="{{ theme.contact_map_embed }}" width="100%" height="250" style="border:0; border-radius: 8px;" allowfullscreen loading="lazy"></iframe>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
