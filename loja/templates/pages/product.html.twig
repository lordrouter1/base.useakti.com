{% extends 'layouts/base.html.twig' %}

{% block title %}{{ product.name|default('Produto') }} — {{ shop.name|default('Minha Loja') }}{% endblock %}
{% block meta_description %}{{ product.description|default('')|striptags|slice(0, 160) }}{% endblock %}

{% block content %}
{% set img = product.main_image_path|default(product.photo_url|default('')) %}

<div class="container-fluid px-3 px-lg-4 py-3">
    {# Breadcrumb #}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small mb-0">
            <li class="breadcrumb-item"><a href="/loja/">Início</a></li>
            <li class="breadcrumb-item"><a href="/loja/produtos">Produtos</a></li>
            {% if product.category_name|default('') %}
                <li class="breadcrumb-item"><a href="/loja/produtos?category={{ product.category_id|default('') }}">{{ product.category_name }}</a></li>
            {% endif %}
            <li class="breadcrumb-item active">{{ product.name|default('Produto')|slice(0, 40) }}</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3 p-md-4">
            <div class="row g-4">
                {# Image gallery #}
                <div class="col-md-5">
                    <div class="product-gallery text-center">
                        {% if img %}
                            <img src="{{ img }}" alt="{{ product.name }}" class="img-fluid rounded mb-3" id="mainImage" style="max-height:400px;object-fit:contain;">
                        {% else %}
                            <img src="/loja/assets/images/placeholder.svg" alt="Sem imagem" class="img-fluid rounded mb-3" style="max-height:400px;">
                        {% endif %}

                        {% if product.images|default([])|length > 1 %}
                            <div class="d-flex gap-2 justify-content-center flex-wrap">
                                {% for image in product.images %}
                                    <img src="{{ image.image_path|default(image) }}" alt="{{ product.name }}"
                                         class="product-thumb rounded border" width="60" height="60"
                                         style="object-fit:cover;cursor:pointer;"
                                         onclick="document.getElementById('mainImage').src=this.src">
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# Product info #}
                <div class="col-md-7">
                    <h1 class="fs-4 fw-bold mb-2">{{ product.name|default('Nome do Produto') }}</h1>

                    {% if product.category_name|default('') %}
                        <div class="mb-2">
                            <a href="/loja/produtos?category={{ product.category_id|default('') }}" class="badge bg-light text-dark border text-decoration-none">
                                {{ product.category_name }}
                            </a>
                            {% if product.subcategory_name|default('') %}
                                <a href="/loja/produtos?category={{ product.category_id|default('') }}&subcategory={{ product.subcategory_id|default('') }}" class="badge bg-light text-dark border text-decoration-none">
                                    {{ product.subcategory_name }}
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}

                    <hr>

                    {% set price = product.price|default(0) %}
                    {% if price > 0 %}
                        <div class="mb-3">
                            <span class="fs-3 fw-bold">R$&nbsp;{{ price|number_format(2, ',', '.') }}</span>
                            <div class="text-success small mt-1">
                                <i class="fas fa-bolt me-1"></i>em até <strong>12x de R$&nbsp;{{ (price / 12)|number_format(2, ',', '.') }}</strong>
                            </div>
                            <div class="text-success small">
                                <i class="fas fa-barcode me-1"></i>R$&nbsp;{{ (price * 0.95)|number_format(2, ',', '.') }} no Pix <span class="badge bg-success">5% OFF</span>
                            </div>
                        </div>
                    {% else %}
                        <p class="text-muted fs-5">Consulte o preço</p>
                    {% endif %}

                    {% if product.free_shipping|default(0) or product.category_free_shipping|default(0) or product.subcategory_free_shipping|default(0) %}
                    <div class="alert alert-success py-2 px-3 mb-3 d-inline-flex align-items-center" style="font-size:0.9rem;">
                        <i class="fas fa-truck me-2"></i><strong>Frete Grátis</strong>
                    </div>
                    {% endif %}

                    {% if product.sku|default('') %}
                        <small class="text-muted d-block mb-2">SKU: {{ product.sku }}</small>
                    {% endif %}

                    {# Quantity + Add to cart #}
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="input-group" style="width:120px;">
                            <button class="btn btn-outline-secondary btn-sm" type="button" onclick="changeQty(-1)">−</button>
                            <input type="number" id="productQty" class="form-control form-control-sm text-center" value="1" min="1" max="999">
                            <button class="btn btn-outline-secondary btn-sm" type="button" onclick="changeQty(1)">+</button>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex">
                        <button class="btn btn-warning btn-lg fw-bold flex-grow-1" type="button" onclick="addToCart({{ product.id|default(0) }})">
                            <i class="fas fa-shopping-cart me-2"></i>Adicionar ao Carrinho
                        </button>
                    </div>

                    {# Trust badges #}
                    <div class="d-flex flex-wrap gap-3 mt-4 pt-3 border-top small text-muted">
                        <span><i class="fas fa-shield-alt me-1"></i>Compra segura</span>
                        <span><i class="fas fa-truck me-1"></i>Entrega para todo Brasil</span>
                        <span><i class="fas fa-undo me-1"></i>Devolução garantida</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Description #}
    {% if product.description|default('') %}
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3 p-md-4">
            <h2 class="fs-5 fw-bold mb-3">Descrição do Produto</h2>
            <div class="product-description">
                {{ product.description|raw }}
            </div>
        </div>
    </div>
    {% endif %}

    {# Related products #}
    {% if related_products|default([])|length > 0 %}
    <section class="mt-3">
        <h2 class="fs-5 fw-bold mb-3">Produtos Relacionados</h2>
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-xl-5 g-2 g-md-3">
            {% for rp in related_products %}
                <div class="col">
                    {% include 'snippets/product-card.html.twig' with {'product': rp} %}
                </div>
            {% endfor %}
        </div>
    </section>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
<script>
function changeQty(delta) {
    const input = document.getElementById('productQty');
    let v = parseInt(input.value) || 1;
    v = Math.max(1, v + delta);
    input.value = v;
}

function addToCart(productId) {
    const qty = parseInt(document.getElementById('productQty').value) || 1;
    fetch('/loja/api/cart/add', {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: 'product_id=' + productId + '&quantity=' + qty
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            {# Update cart badge #}
            document.querySelectorAll('.badge.bg-danger').forEach(b => {
                b.textContent = data.cart_count;
                b.style.display = '';
            });
            {# Brief visual feedback #}
            const btn = event.target.closest('button');
            const orig = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check me-2"></i>Adicionado!';
            btn.classList.replace('btn-warning', 'btn-success');
            setTimeout(() => { btn.innerHTML = orig; btn.classList.replace('btn-success', 'btn-warning'); }, 1500);
        }
    })
    .catch(() => {});
}
</script>
{% endblock %}
