{% extends 'layouts/base.html.twig' %}

{% block title %}{{ product.name|default('Produto') }} — {{ shop.name|default('Minha Loja') }}{% endblock %}

{% block meta_description %}{{ product.description|default('')|striptags|slice(0, 160) }}{% endblock %}

{% block content %}
<section class="py-5">
    <div class="container">
        {% include 'snippets/breadcrumb.html.twig' with {'items': [
            {'label': 'Início', 'url': '/'},
            {'label': product.category|default('Produtos'), 'url': '/produtos'},
            {'label': product.name|default('Produto')}
        ]} %}

        <div class="row g-4">
            {# Galeria de imagens #}
            <div class="col-md-6">
                <div class="product-gallery">
                    {% if product.images|default([])|length > 0 %}
                        <img src="{{ product.images[0] }}" alt="{{ product.name }}" class="img-fluid rounded mb-3 w-100">
                        <div class="row g-2">
                            {% for image in product.images %}
                                <div class="col-3">
                                    <img src="{{ image }}" alt="{{ product.name }}" class="img-fluid rounded product-thumb cursor-pointer">
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <img src="/loja/assets/images/placeholder.svg" alt="Sem imagem" class="img-fluid rounded w-100">
                    {% endif %}
                </div>
            </div>

            {# Detalhes do produto #}
            <div class="col-md-6">
                <h1 class="h2 mb-3">{{ product.name|default('Nome do Produto') }}</h1>

                {% include 'snippets/price.html.twig' with {'price': product.price|default(0), 'original_price': product.original_price|default(null)} %}

                <div class="my-4">
                    {{ product.description|default('Descrição do produto.')|raw }}
                </div>

                <div class="d-grid gap-2">
                    <button class="btn btn-primary btn-lg" type="button">
                        <i class="fas fa-shopping-cart me-2"></i>Adicionar ao Carrinho
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
