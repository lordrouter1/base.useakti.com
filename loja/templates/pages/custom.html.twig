{% extends 'layouts/base.html.twig' %}

{% block title %}{{ page.title|default('Página') }} — {{ shop.name|default('Minha Loja') }}{% endblock %}

{% block content %}
    {% for section in sections|default([]) %}
        {% set template_name = 'sections/' ~ section.type ~ '.html.twig' %}
        {% set section_settings = section.settings is defined ? section.settings : {} %}
        {% set section_data = section.data is defined ? section.data : {} %}
        {% include template_name ignore missing with {
            'settings': section_settings,
            'data': section_data
        } %}
    {% else %}
        <section class="py-5">
            <div class="container">
                <h1>{{ page.title|default('Página') }}</h1>
                <div>{{ page.content|default('')|raw }}</div>
            </div>
        </section>
    {% endfor %}
{% endblock %}
