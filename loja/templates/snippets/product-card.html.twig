{# Product Card - E-commerce style #}
{% set img = product.main_image_path|default(product.photo_url|default(product.image|default(''))) %}
{% set pid = product.slug|default(product.id|default('#')) %}
<article class="card border-0 product-card h-100">
    <a href="/loja/produto/{{ pid }}" class="product-card-img" aria-label="Ver mais detalhes do produto">
        {% if img %}
            <img src="{{ img }}" alt="{{ product.name|default('Produto') }}" loading="lazy">
        {% else %}
            <img src="/loja/assets/images/placeholder.svg" alt="Sem imagem" loading="lazy">
        {% endif %}
    </a>
    <div class="card-body d-flex flex-column p-3">
        {% if product.category_name|default('') %}
            <small class="text-muted text-uppercase d-block mb-1" style="font-size: 0.70rem; letter-spacing: 0.5px;">{{ product.category_name }}</small>
        {% endif %}
        <a href="/loja/produto/{{ pid }}" class="text-decoration-none">
            <h6 class="product-card-title mb-2">{{ product.name|default('Produto') }}</h6>
        </a>
        <div class="mt-auto">
            {% set price = product.price|default(0) %}
            {% if price > 0 %}
                <div class="product-price mb-1">
                    <span aria-label="Preço: R$ {{ price|number_format(2, ',', '.') }}">R$ {{ price|number_format(2, ',', '.') }}</span>
                </div>
                <small class="text-muted d-block lh-1">
                    em 12x de R$ {{ (price / 12)|number_format(2, ',', '.') }}
                </small>
                {% if product.free_shipping|default(0) or product.category_free_shipping|default(0) or product.subcategory_free_shipping|default(0) %}
                <div class="product-shipping mt-2">
                    <i class="fas fa-truck fa-sm me-1"></i>Frete Grátis
                </div>
                {% endif %}
            {% else %}
                <span class="text-muted small">Consulte o preço</span>
            {% endif %}
        </div>
    </div>
</article>
