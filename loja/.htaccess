# Akti — Loja Online
# Rewrite rules para URLs amigáveis

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /loja/

    # Arquivos e diretórios existentes passam direto (assets, imagens, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Tudo o mais vai para index.php com a rota capturada
    RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>

# Segurança — bloquear acesso direto a config e templates
<FilesMatch "\.(twig|json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Cache de assets estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
