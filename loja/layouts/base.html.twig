<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ shop.name|default('Minha Loja') }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{{ shop.description|default('') }}{% endblock %}">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family={{ theme.body_font|default('Inter') }}:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Theme CSS -->
    <link rel="stylesheet" href="/loja/assets/css/theme.css">

    <style>
        :root {
            --primary-color: {{ theme.primary_color|default('#3b82f6') }};
            --secondary-color: {{ theme.secondary_color|default('#64748b') }};
            --accent-color: {{ theme.accent_color|default('#f59e0b') }};
            --body-font: '{{ theme.body_font|default('Inter') }}', sans-serif;
            --heading-font: '{{ theme.heading_font|default('Inter') }}', sans-serif;
        }
        body {
            font-family: var(--body-font);
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: var(--heading-font);
        }
    </style>
    {% block head_extra %}{% endblock %}
</head>
<body>
    {% include 'sections/header.html.twig' %}

    <main>
        {% block content %}{% endblock %}
    </main>

    {% include 'sections/footer.html.twig' %}

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Theme JS -->
    <script src="/loja/assets/js/theme.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
